# ── qMetry ─────────────────────────────────────────────────────────────────
# Generate from: Jira → QMetry → Configuration → Open API → Generate
QMETRY_API_KEY=your-qmetry-api-key-here

# Base URL for the qMetry REST API.
# Cloud default (usually correct):
QMETRY_BASE_URL=https://qtmcloud.qmetry.com/rest/api/latest/
#
# If your team uses a self-hosted Jira + QTM4J plugin, override with:
# QMETRY_BASE_URL=https://your-jira.company.com/rest/qtm4j/v2/
